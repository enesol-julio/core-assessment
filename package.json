{
  "name": "core-assessment",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "validate:content": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate/content.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file-if-exists=.env.local --disable-warning=MODULE_TYPELESS_PACKAGE_JSON src/db/migrate.ts",
    "db:seed": "node --env-file-if-exists=.env.local --disable-warning=MODULE_TYPELESS_PACKAGE_JSON src/db/seed.ts",
    "db:drop": "drizzle-kit drop",
    "db:studio": "drizzle-kit studio",
    "smoke:auth": "tsx scripts/validate/auth-smoke.mjs",
    "smoke:domains": "tsx scripts/validate/domains-smoke.mjs",
    "smoke:scoring": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate/scoring-smoke.mjs",
    "smoke:auth-gate": "tsx scripts/validate/auth-gate-smoke.mjs"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.3",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
